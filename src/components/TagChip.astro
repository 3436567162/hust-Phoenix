---
interface Props {
  label: string;
  href?: string;
}

const { label, href } = Astro.props;
---

{
  href ? (
    <a class="tag-chip" href={href}>
      #{label}
    </a>
  ) : (
    <span class="tag-chip">#{label}</span>
  )
}

<style>
  .tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0.34rem 0.72rem;
    border: 1px solid rgba(154, 52, 18, 0.14);
    border-radius: var(--radius-pill);
    background: rgba(255, 247, 239, 0.78);
    color: var(--accent-deep);
    font-size: 0.85rem;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .tag-chip:hover {
    background: rgba(154, 52, 18, 0.12);
  }
</style>
